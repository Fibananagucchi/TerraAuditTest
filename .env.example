# TerraAudit — Environment Variables
# Copy this file to .env and fill in your keys:
# cp .env.example .env

# ── Google Earth Engine ──────────────────────
# Your GCP project ID (create at console.cloud.google.com)
# Must have Earth Engine API enabled
GEE_PROJECT=your-google-cloud-project-id

# ── Groq LLM ─────────────────────────────────
# Free API key at https://console.groq.com
# Used for investment teaser generation (optional)
GROQ_API_KEY=your-groq-api-key-here
